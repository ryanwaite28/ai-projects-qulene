{
  "name": "qulene-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Qulene — Waitlist & Appointment Request Manager (monorepo root)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "bootstrap:local": "./infra/scripts/bootstrap.sh --local",
    "bootstrap": "./infra/scripts/bootstrap.sh",
    "seed:local": "npx tsx infra/scripts/seed-local.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
