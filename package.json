{
  "name": "qulene-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Qulene — Waitlist & Appointment Request Manager (monorepo root)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "bootstrap:local": "./infra/scripts/bootstrap.sh --local",
    "bootstrap": "./infra/scripts/bootstrap.sh",
    "deploy:local": "bash infra/scripts/deploy-local.sh",
    "seed:local": "npx tsx infra/scripts/seed-local.ts"
  },
  "overrides": {
    "metro": "0.81.5",
    "metro-config": "0.81.5",
    "metro-core": "0.81.5",
    "metro-cache": "0.81.5",
    "metro-cache-key": "0.81.5",
    "metro-transform-worker": "0.81.5",
    "metro-babel-transformer": "0.81.5",
    "metro-runtime": "0.81.5",
    "metro-source-map": "0.81.5",
    "metro-resolver": "0.81.5",
    "metro-file-map": "0.81.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
