# ─────────────────────────────────────────────────────────────────────────────
# Qulene .env.example
#
# Copy this file to .env for local development. Never commit .env.
# In deployed environments (dev/prod), these values come from
# qulene-{env}-secrets in AWS Secrets Manager — there is no .env on Lambda.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Backend (local development only) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# MiniStack endpoints (all 35+ services on port 4566)
DYNAMODB_ENDPOINT=http://localhost:4566
SNS_ENDPOINT=http://localhost:4566
SQS_ENDPOINT=http://localhost:4566
SES_ENDPOINT=http://localhost:4566
S3_ENDPOINT=http://localhost:4566

# Email config
SES_FROM_EMAIL=no-reply@qulene.com

# Local-stack queue + topic ARNs (account 000000000000 is MiniStack's default)
NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/qulene-local-notifications
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:qulene-local-events

# Cognito (mock values for local dev — replaced by real values from SSM in dev/prod)
COGNITO_USER_POOL_ID=us-east-1_localpool
COGNITO_CLIENT_ID=localclientid

# S3 buckets
MEDIA_BUCKET=qulene-local-media

# DynamoDB tables (per-phase; full table name format is `qulene-{env}-{table}`)
USERS_TABLE=qulene-local-users
BUSINESS_PROFILES_TABLE=qulene-local-business-profiles
SERVICES_TABLE=qulene-local-services
AVAILABILITY_WINDOWS_TABLE=qulene-local-availability-windows
APPOINTMENT_REQUESTS_TABLE=qulene-local-appointment-requests
WAITLIST_ENTRIES_TABLE=qulene-local-waitlist-entries
NOTIFICATIONS_TABLE=qulene-local-notifications
WEB_SIGNUPS_TABLE=qulene-local-web-signups

# Admin contact (used by lambda-contact + alarms)
ADMIN_EMAIL=admin@qulene.com

# ─── Mobile (apps/mobile/.env — never committed) ───
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_localpool
EXPO_PUBLIC_COGNITO_CLIENT_ID=localclientid
