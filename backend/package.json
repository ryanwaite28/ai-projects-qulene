{
  "name": "@qulene/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Qulene backend — Lambda handlers, services, and DynamoDB table helpers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && tsx esbuild.config.ts",
